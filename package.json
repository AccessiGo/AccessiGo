{
  "name": "accessigo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "python3 -m flask --app app run --host 127.0.0.1 --port 5000",
    "dev:backend:lan": "python3 -m flask --app app run --host 0.0.0.0 --port 5000",
    "dev:frontend": "npm --prefix frontend run dev -- --host 127.0.0.1",
    "dev:mobile": "npm --prefix mobile run start --",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview -- --host 127.0.0.1"
  },
  "workspaces": [
    "frontend",
    "mobile"
  ]
}
